{
  "manifest_version": 3,
  "name": "X Media Gallery — Download Photos & Videos",
  "short_name": "X Gallery",
  "version": "0.8.1",
  "description": "Browse your X (Twitter) timeline as a media gallery and download photos and videos — videos save with sound.",
  "permissions": ["webRequest", "storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://video.twimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["hls.min.js", "content.js"],
      "css": ["gallery.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Toggle X Media Gallery",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
